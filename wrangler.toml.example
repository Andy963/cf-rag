name = "cf-rag"
main = "src/index.ts"
compatibility_date = "2026-03-03"
workers_dev = true
preview_urls = true

[ai]
binding = "AI"

[[d1_databases]]
binding = "DB"
database_name = "cf-text"
database_id = "<YOUR_D1_DATABASE_ID>"

[[vectorize]]
binding = "SEGMENTS_INDEX"
index_name = "cf-vector"

# Optional: bind a custom domain route (uncomment and edit).
#
# [[routes]]
# pattern = "emb.example.com/*"
# zone_name = "example.com"

[vars]
CORS_ALLOW_ORIGIN = "*"
EMBEDDING_MODEL = "@cf/baai/bge-m3"

